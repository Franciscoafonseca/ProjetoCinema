@page "/minhas-compras"
@attribute [Authorize]
@inject CompraService CompraService
@inject VisualizacaoService VisualizacaoService
@inject NavigationManager Nav

<PageTitle>Minhas compras - Online Cinema Festival</PageTitle>

<div class="historico-page">
    <header class="page-header">
        <div>
            <p class="eyebrow">Historico</p>
            <h1>Compras e visualizacoes</h1>
            <p>Consulta transacoes, pagamentos simulados e os conteudos que ja abriste no player.</p>
        </div>
        <div class="header-actions">
            <a href="/meus-acessos">Meus acessos</a>
            <a href="/carrinho">Carrinho</a>
        </div>
    </header>

    @if (_aCarregar)
    {
        <p class="estado">A carregar historico...</p>
    }
    else if (!string.IsNullOrWhiteSpace(_erro))
    {
        <p class="estado erro">@_erro</p>
    }
    else
    {
        <section class="metricas">
            <article>
                <span>@_compras.Count</span>
                <small>Compras</small>
            </article>
            <article>
                <span>@Moeda(_compras.Sum(c => c.ValorTotal))</span>
                <small>Total gasto</small>
            </article>
            <article>
                <span>@_visualizacoes.Count</span>
                <small>Visualizacoes</small>
            </article>
        </section>

        <section class="secao">
            <div class="secao-topo">
                <h2>Compras</h2>
                <a href="/sessoes">Comprar mais</a>
            </div>

            @if (_compras.Count == 0)
            {
                <div class="empty-state">
                    <h3>Ainda nao existem compras</h3>
                    <p>Quando finalizares o carrinho, as compras aparecem aqui com pagamento e itens.</p>
                </div>
            }
            else
            {
                <div class="lista">
                    @foreach (var compra in _compras.OrderByDescending(c => c.CriadaEm))
                    {
                        <article class="compra">
                            <div class="compra-topo">
                                <div>
                                    <span class="estado-compra">@compra.EstadoNome</span>
                                    <h3>@compra.Referencia</h3>
                                    <p>@compra.CriadaEm.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                                </div>
                                <strong>@Moeda(compra.ValorTotal)</strong>
                            </div>

                            @if (compra.Pagamento != null)
                            {
                                <div class="pagamento">
                                    <span>@compra.Pagamento.Metodo</span>
                                    <span>@compra.Pagamento.EstadoNome</span>
                                    <span>@compra.Pagamento.Referencia</span>
                                </div>
                            }

                            <ul>
                                @foreach (var item in compra.Itens)
                                {
                                    <li>
                                        <span>
                                            <strong>@item.NomeAcesso</strong>
                                            <small>@item.TipoAcessoNome x @item.Quantidade</small>
                                        </span>
                                        <span>@Moeda(item.Subtotal)</span>
                                    </li>
                                }
                            </ul>
                        </article>
                    }
                </div>
            }
        </section>

        <section class="secao">
            <div class="secao-topo">
                <h2>Visualizacoes</h2>
                <a href="/catalogo">Explorar catalogo</a>
            </div>

            @if (_visualizacoes.Count == 0)
            {
                <div class="empty-state">
                    <h3>Ainda nao existem visualizacoes registadas</h3>
                    <p>Ao abrir um filme ou sessao no player, o historico fica registado aqui.</p>
                </div>
            }
            else
            {
                <div class="lista compacta">
                    @foreach (var visualizacao in _visualizacoes.OrderByDescending(v => v.VisualizadoEm))
                    {
                        <article class="visualizacao">
                            <div>
                                <span class="estado-compra">@visualizacao.TipoConteudo</span>
                                <h3>@visualizacao.FilmeTitulo</h3>
                                <p>@DescricaoVisualizacao(visualizacao)</p>
                            </div>
                            <div class="visualizacao-acoes">
                                <time>@visualizacao.VisualizadoEm.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</time>
                                <button @onclick="() => Reabrir(visualizacao)">Reabrir</button>
                            </div>
                        </article>
                    }
                </div>
            }
        </section>
    }
</div>

@code {
    private List<CompraDto> _compras = new();
    private List<VisualizacaoHistoricoDto> _visualizacoes = new();
    private bool _aCarregar = true;
    private string? _erro;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _compras = await CompraService.ObterMinhasAsync();
            _visualizacoes = await VisualizacaoService.ObterHistoricoAsync();
        }
        catch (Exception ex)
        {
            _erro = ex.Message;
        }
        finally
        {
            _aCarregar = false;
        }
    }

    private void Reabrir(VisualizacaoHistoricoDto visualizacao)
    {
        if (visualizacao.SessaoId.HasValue)
        {
            Nav.NavigateTo($"/player/sessao/{visualizacao.SessaoId.Value}");
            return;
        }

        Nav.NavigateTo($"/player/filme/{visualizacao.FilmeId}");
    }

    private static string DescricaoVisualizacao(VisualizacaoHistoricoDto visualizacao)
    {
        if (!string.IsNullOrWhiteSpace(visualizacao.FestivalNome))
            return visualizacao.FestivalNome;

        if (visualizacao.SessaoId.HasValue)
            return $"Sessao #{visualizacao.SessaoId}";

        return "Filme digital";
    }

    private static string Moeda(decimal valor)
    {
        return valor.ToString("C", new System.Globalization.CultureInfo("pt-PT"));
    }
}
