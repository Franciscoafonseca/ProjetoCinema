@page "/perfil"

<PageTitle>Perfil — Online Cinema Festival</PageTitle>

<div class="premium-shell">
    <section class="profile-hero">
        <div class="hero-left">
            <div class="avatar-ring">
                <img src="@PerfilData.AvatarUrl" alt="@PerfilData.Username" />
            </div>
            <div class="hero-meta">
                <h1>@PerfilData.Username</h1>
                <div class="flag-chip">
                    <span class="flag">@PerfilData.CountryFlag</span>
                    <span>@PerfilData.CountryName</span>
                </div>
            </div>
        </div>
        <div class="hero-stats">
            @foreach (var stat in PerfilData.Stats)
            {
                <div class="stat-card">
                    <span class="stat-label">@stat.Label</span>
                    <span class="stat-value">@stat.Value</span>
                </div>
            }
        </div>
    </section>

    <section class="reviews-section">
        <div class="section-header">
            <h2>Reviews From Users</h2>
            <div class="accent-bar"></div>
        </div>
        <div class="reviews-grid">
            @foreach (var review in Reviews)
            {
                <article class="review-card">
                    <div class="review-top">
                        <span class="review-name">@review.Name</span>
                        <div class="review-stars">
                            @for (var i = 0; i < review.Stars; i++)
                            {
                                <span class="star red">★</span>
                            }
                            @for (var i = review.Stars; i < 5; i++)
                            {
                                <span class="star">★</span>
                            }
                        </div>
                    </div>
                    <p>@review.Text</p>
                </article>
            }
        </div>
    </section>

    <section class="chosen-section">
        <div class="section-header">
            <h2>Chosen List</h2>
            <div class="accent-bar"></div>
        </div>
        <div class="chosen-grid">
            @foreach (var poster in ChosenList)
            {
                <div class="poster-card">
                    <img src="@poster" alt="Poster" />
                </div>
            }
        </div>
    </section>
</div>

@code {
    private readonly PerfilMock PerfilData = new()
    {
        Username = "Jony Macarrony",
        AvatarUrl = "https://images.unsplash.com/photo-1544723795-3fb6469f5b39?q=80&w=300&auto=format&fit=crop",
        CountryFlag = "🇵🇹",
        CountryName = "Portugal",
        Stats = new List<StatItem>
        {
            new("Followers", "12.4K"),
            new("Following", "821"),
            new("Community", "07"),
            new("Languages", "PT/EN")
        }
    };

    private readonly List<ReviewItem> Reviews = new()
    {
        new("Marta L.", "Atmosfera impecavel e escolhas arrojadas.", 5),
        new("Alex R.", "Excelente curadoria e eventos memoraveis.", 4),
        new("Nuno V.", "Uma experiencia premium do inicio ao fim.", 5),
        new("Sofia K.", "Cinematografia moderna e vibrante.", 4)
    };

    private readonly List<string> ChosenList = new()
    {
        "https://images.unsplash.com/photo-1517602302552-471fe67acf66?q=80&w=400&auto=format&fit=crop",
        "https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?q=80&w=400&auto=format&fit=crop",
        "https://images.unsplash.com/photo-1524985069026-dd778a71c7b4?q=80&w=400&auto=format&fit=crop",
        "https://images.unsplash.com/photo-1524985069026-dd778a71c7b4?q=80&w=400&auto=format&fit=crop",
        "https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?q=80&w=400&auto=format&fit=crop"
    };

    private sealed class PerfilMock
    {
        public string Username { get; set; } = string.Empty;
        public string AvatarUrl { get; set; } = string.Empty;
        public string CountryFlag { get; set; } = string.Empty;
        public string CountryName { get; set; } = string.Empty;
        public List<StatItem> Stats { get; set; } = new();
    }

    private sealed record StatItem(string Label, string Value);

    private sealed record ReviewItem(string Name, string Text, int Stars);
}
