@page "/perfil"
@inject PerfilService PerfilService
@inject NavigationManager Nav

<PageTitle>Perfil — Online Cinema Festival</PageTitle>

<AuthorizeView>
    <NotAuthorized>
        @{ Nav.NavigateTo("/login?returnUrl=/perfil", forceLoad: false); }
    </NotAuthorized>
    <Authorized Context="auth">
        <div class="perfil-container">
            @if (_loading)
            {
                <div class="loading-state">
                    <div class="spinner"></div>
                    <p>A carregar perfil...</p>
                </div>
            }
            else if (_erro != null)
            {
                <p class="erro-state">@_erro</p>
            }
            else if (_perfil != null)
            {
                @if (!_emEdicao)
                {
                    <div class="perfil-card">
                        <div class="perfil-cabecalho">
                            <div class="perfil-avatar">
                                @if (!string.IsNullOrWhiteSpace(_perfil.ProfileImageUrl))
                                {
                                    <img src="@_perfil.ProfileImageUrl" alt="@_perfil.Name" />
                                }
                                else
                                {
                                    <span class="perfil-avatar-inicial">@ObterInicial(_perfil.Name)</span>
                                }
                            </div>
                            <div class="perfil-titulo">
                                <h1>@_perfil.Name</h1>
                                <p class="perfil-email">@_perfil.Email</p>
                                @if (_perfil.IsPublic)
                                {
                                    <span class="perfil-badge publico">Perfil público</span>
                                }
                                else
                                {
                                    <span class="perfil-badge privado">Perfil privado</span>
                                }
                            </div>
                            <button class="btn-editar" @onclick="EntrarEdicao">Editar</button>
                        </div>

                        <div class="perfil-info">
                            @if (!string.IsNullOrWhiteSpace(_perfil.Bio))
                            {
                                <p class="perfil-bio">@_perfil.Bio</p>
                            }

                            <div class="perfil-detalhes">
                                @if (!string.IsNullOrWhiteSpace(_perfil.Nationality))
                                {
                                    <div class="detalhe">
                                        <span class="detalhe-label">Nacionalidade</span>
                                        <span>@_perfil.Nationality</span>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(_perfil.Location))
                                {
                                    <div class="detalhe">
                                        <span class="detalhe-label">Localização</span>
                                        <span>@_perfil.Location</span>
                                    </div>
                                }
                            </div>

                            @if (_perfil.FavoriteGenres.Any())
                            {
                                <div class="perfil-generos">
                                    <span class="detalhe-label">Géneros favoritos</span>
                                    <div class="generos-lista">
                                        @foreach (var g in _perfil.FavoriteGenres)
                                        {
                                            <span class="genero-chip">@g</span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="perfil-stats">
                            <div class="stat">
                                <div class="stat-valor">@_perfil.ReviewsCount</div>
                                <div class="stat-label">Avaliações</div>
                            </div>
                            <div class="stat">
                                <div class="stat-valor">@_perfil.CommunitiesCount</div>
                                <div class="stat-label">Comunidades</div>
                            </div>
                            <div class="stat">
                                <div class="stat-valor">@_perfil.PublicListsCount</div>
                                <div class="stat-label">Listas públicas</div>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="perfil-card">
                        <h2 class="form-titulo">Editar perfil</h2>

                        <EditForm Model="_pedido" OnValidSubmit="Guardar">
                            <DataAnnotationsValidator />

                            <div class="form-campo">
                                <label>Nome</label>
                                <InputText class="form-input" @bind-Value="_pedido.Name" />
                                <ValidationMessage For="@(() => _pedido.Name)" class="auth-erro-campo" />
                            </div>

                            <div class="form-campo">
                                <label>Nacionalidade</label>
                                <InputText class="form-input" @bind-Value="_pedido.Nationality" />
                            </div>

                            <div class="form-campo">
                                <label>Localização</label>
                                <InputText class="form-input" @bind-Value="_pedido.Location" />
                            </div>

                            <div class="form-campo">
                                <label>URL da foto de perfil</label>
                                <InputText class="form-input" @bind-Value="_pedido.ProfileImageUrl" />
                            </div>

                            <div class="form-campo">
                                <label>Biografia</label>
                                <InputTextArea class="form-input form-textarea" @bind-Value="_pedido.Bio" rows="4" />
                            </div>

                            <div class="form-campo-check">
                                <InputCheckbox @bind-Value="_pedido.IsPublic" id="ispublic" />
                                <label for="ispublic">Perfil público</label>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(_erroEdicao))
                            {
                                <p class="auth-erro-geral">@_erroEdicao</p>
                            }

                            <div class="form-acoes">
                                <button type="button" class="btn-secundario" @onclick="CancelarEdicao">Cancelar</button>
                                <button type="submit" class="btn-primario" disabled="@_aGuardar">
                                    @(_aGuardar ? "A guardar..." : "Guardar alterações")
                                </button>
                            </div>
                        </EditForm>
                    </div>
                }
            }
        </div>
    </Authorized>
</AuthorizeView>

@code {
    private UserProfileResponse? _perfil;
    private UpdateProfileRequest _pedido = new();
    private bool _loading = true;
    private bool _emEdicao;
    private bool _aGuardar;
    private string? _erro;
    private string? _erroEdicao;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _perfil = await PerfilService.GetMeuPerfilAsync();
            if (_perfil == null)
                _erro = "Não foi possível carregar o perfil. Verifica se tens sessão iniciada.";
        }
        catch
        {
            _erro = "Erro ao carregar o perfil. Tenta novamente.";
        }
        finally
        {
            _loading = false;
        }
    }

    private void EntrarEdicao()
    {
        if (_perfil == null) return;

        _pedido = new UpdateProfileRequest
        {
            Name = _perfil.Name,
            Nationality = _perfil.Nationality,
            Bio = _perfil.Bio,
            ProfileImageUrl = _perfil.ProfileImageUrl,
            Location = _perfil.Location,
            IsPublic = _perfil.IsPublic,
            FavoriteGenreIds = new(),
        };
        _erroEdicao = null;
        _emEdicao = true;
    }

    private void CancelarEdicao()
    {
        _emEdicao = false;
        _erroEdicao = null;
    }

    private async Task Guardar()
    {
        _aGuardar = true;
        _erroEdicao = null;

        try
        {
            var atualizado = await PerfilService.AtualizarMeuPerfilAsync(_pedido);
            if (atualizado != null)
                _perfil = atualizado;
            _emEdicao = false;
        }
        catch (Exception ex)
        {
            _erroEdicao = ex.Message;
        }
        finally
        {
            _aGuardar = false;
        }
    }

    private static string ObterInicial(string nome)
    {
        return string.IsNullOrWhiteSpace(nome) ? "?" : nome.Trim()[..1].ToUpperInvariant();
    }
}
