@page "/festivais/{Id:int}"
@inherits FilmePageBase
@inject FestivalService FestivalService
@inject SessaoService SessaoService
@inject AcessoService AcessoService
@inject CarrinhoService CarrinhoService
@inject NavigationManager Nav

<PageTitle>@(_festival?.Name ?? "Festival") - Online Cinema Festival</PageTitle>

@if (_loading)
{
    <div class="loading-state">
        <div class="spinner"></div>
        <p>A carregar festival...</p>
    </div>
}
else if (_erro != null)
{
    <div class="festival-erro">
        <p class="erro-state">@_erro</p>
        <button class="btn-voltar" @onclick="Voltar">Voltar aos festivais</button>
    </div>
}
else if (_festival == null)
{
    <div class="festival-erro">
        <h2>Festival nao encontrado</h2>
        <button class="btn-voltar" @onclick="Voltar">Voltar aos festivais</button>
    </div>
}
else
{
    <div class="festival-detalhes-container">
        <button class="btn-voltar" @onclick="Voltar">Voltar aos festivais</button>

        <section class="festival-hero">
            <span class="festival-hero-data">@FormatarPeriodo(_festival.StartDate, _festival.EndDate)</span>
            <h1 class="festival-hero-titulo">@_festival.Name</h1>
            @if (!string.IsNullOrWhiteSpace(_festival.Description))
            {
                <p class="festival-hero-descricao">@_festival.Description</p>
            }
            <div class="festival-hero-metrics">
                <span>@_filmes.Count filmes</span>
                <span>@_sessoes.Count sessoes</span>
                <span>@EstadoFestival(_festival)</span>
            </div>
        </section>

        <section class="festival-seccao">
            <div class="seccao-cabecalho">
                <h2 class="seccao-titulo">Passes</h2>
                <a href="/carrinho">Ver carrinho</a>
            </div>

            @if (AcessosDoFestival.Count == 0)
            {
                <p class="empty-state">Ainda nao ha passes configurados para este festival.</p>
            }
            else
            {
                <div class="passes-lista">
                    @foreach (var acesso in AcessosDoFestival)
                    {
                        <article class="passe-item">
                            <div>
                                <h3>@acesso.Nome</h3>
                                <p>@DescricaoAcesso(acesso)</p>
                            </div>
                            <div class="passe-acoes">
                                <strong>@Moeda(acesso.Preco)</strong>
                                <button @onclick="() => AdicionarPasse(acesso)" disabled="@_aAtualizarCarrinho">
                                    Adicionar
                                </button>
                            </div>
                        </article>
                    }
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(_mensagemCarrinho))
            {
                <p class="carrinho-feedback">@_mensagemCarrinho</p>
            }
        </section>

        <section class="festival-seccao">
            <div class="seccao-cabecalho">
                <h2 class="seccao-titulo">Sessoes</h2>
                <a href="/sessoes">Programacao completa</a>
            </div>

            @if (_sessoes.Count == 0)
            {
                <p class="empty-state">Ainda nao ha sessoes programadas.</p>
            }
            else
            {
                <div class="sessoes-lista">
                    @foreach (var sessao in _sessoes)
                    {
                        <article class="sessao-item">
                            <div class="sessao-data">
                                <div class="sessao-dia">@sessao.Inicio.ToLocalTime().ToString("dd")</div>
                                <div class="sessao-mes">@sessao.Inicio.ToLocalTime().ToString("MMM").ToUpperInvariant()</div>
                            </div>

                            <div class="sessao-info">
                                <div class="sessao-linha">
                                    <h3 class="sessao-filme">@TituloSessao(sessao)</h3>
                                    <span class="sessao-estado @EstadoCss(EstadoTexto(sessao))">@EstadoTexto(sessao)</span>
                                </div>
                                <div class="sessao-hora">
                                    @sessao.TipoNome - @sessao.Inicio.ToLocalTime().ToString("HH:mm") - @sessao.Fim.ToLocalTime().ToString("HH:mm")
                                </div>
                                @if (!string.IsNullOrWhiteSpace(sessao.Observacoes))
                                {
                                    <p class="sessao-obs">@sessao.Observacoes</p>
                                }
                            </div>

                            <div class="sessao-acoes">
                                <button class="sessao-btn destaque"
                                        disabled="@(_aAtualizarCarrinho || SessaoTerminada(sessao))"
                                        @onclick="() => AdicionarBilhete(sessao.Id)">
                                    Bilhete
                                </button>
                                <button class="sessao-btn" @onclick="() => AbrirPlayer(sessao.Id)">
                                    Player
                                </button>
                                @if (sessao.FilmePrincipalId.HasValue)
                                {
                                    <button class="sessao-btn" @onclick="() => AbrirFilme(sessao.FilmePrincipalId.Value)">
                                        Filme
                                    </button>
                                }
                            </div>
                        </article>
                    }
                </div>
            }
        </section>

        <section class="festival-seccao">
            <h2 class="seccao-titulo">Filmes no festival</h2>
            @if (_filmes.Count == 0)
            {
                <p class="empty-state">Ainda nao ha filmes associados a este festival.</p>
            }
            else
            {
                <div class="filmes-grid">
                    @foreach (var filme in _filmes)
                    {
                        <FilmeCard Filme="filme" />
                    }
                </div>
            }
        </section>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private FestivalDTO? _festival;
    private List<FilmeDTO> _filmes = new();
    private List<SessaoDTO> _sessoes = new();
    private List<AcessoDTO> _acessos = new();
    private bool _aAtualizarCarrinho;
    private string? _mensagemCarrinho;

    private List<AcessoDTO> AcessosDoFestival =>
        _acessos
            .Where(a =>
                a.IsAtivo
                && a.FestivalId == Id
                && a.SessaoId == null
                && a.FilmeId == null
            )
            .OrderBy(a => a.Tipo)
            .ThenBy(a => a.DataAcesso)
            .ThenBy(a => a.Preco)
            .ToList();

    protected override async Task CarregarDadosAsync()
    {
        _festival = await FestivalService.ObterFestivalPorIdAsync(Id);

        if (_festival == null)
            return;

        _filmes = await FestivalService.ObterFilmesDoFestivalAsync(Id);
        _sessoes = (await SessaoService.ObterSessoesPorFestivalAsync(Id))
            .OrderBy(s => s.Inicio)
            .ToList();
        _acessos = await AcessoService.ObterAcessosAsync();
    }

    private async Task AdicionarPasse(AcessoDTO acesso)
    {
        await ExecutarCarrinho(async () =>
        {
            if (acesso.Tipo == TiposAcesso.PasseDiario && acesso.DataAcesso.HasValue)
            {
                await CarrinhoService.AdicionarPasseDiarioAsync(Id, acesso.DataAcesso.Value);
            }
            else if (acesso.Tipo == TiposAcesso.PasseCompleto)
            {
                await CarrinhoService.AdicionarPasseCompletoAsync(Id);
            }
            else
            {
                await CarrinhoService.AdicionarItemAsync(acesso.Id);
            }

            _mensagemCarrinho = "Acesso adicionado ao carrinho.";
        });
    }

    private async Task AdicionarBilhete(int sessaoId)
    {
        await ExecutarCarrinho(async () =>
        {
            await CarrinhoService.AdicionarBilheteSessaoAsync(sessaoId);
            _mensagemCarrinho = "Bilhete adicionado ao carrinho.";
        });
    }

    private async Task ExecutarCarrinho(Func<Task> acao)
    {
        _mensagemCarrinho = null;
        _aAtualizarCarrinho = true;

        try
        {
            await acao();
        }
        catch (Exception ex)
        {
            _mensagemCarrinho = ex.Message;
        }
        finally
        {
            _aAtualizarCarrinho = false;
        }
    }

    private void Voltar() => Nav.NavigateTo("/festivais");

    private void AbrirFilme(int filmeId) => Nav.NavigateTo($"/filmes/{filmeId}");

    private void AbrirPlayer(int sessaoId) => Nav.NavigateTo($"/visualizar/sessao/{sessaoId}");

    private static string TituloSessao(SessaoDTO sessao)
    {
        return string.IsNullOrWhiteSpace(sessao.Filme) ? $"Sessao #{sessao.Id}" : sessao.Filme;
    }

    private static string DescricaoAcesso(AcessoDTO acesso)
    {
        if (acesso.Tipo == TiposAcesso.PasseDiario && acesso.DataAcesso.HasValue)
            return $"{acesso.TipoNome} - {acesso.DataAcesso.Value.ToLocalTime():dd/MM/yyyy}";

        return acesso.TipoNome;
    }

    private static bool SessaoTerminada(SessaoDTO sessao)
    {
        return string.Equals(EstadoTexto(sessao), "Terminada", StringComparison.OrdinalIgnoreCase)
            || sessao.Fim.ToUniversalTime() <= DateTime.UtcNow;
    }

    private static string EstadoTexto(SessaoDTO sessao)
    {
        if (!string.IsNullOrWhiteSpace(sessao.Estado))
            return sessao.Estado;

        var agora = DateTime.UtcNow;
        if (sessao.Inicio.ToUniversalTime() > agora)
            return "Agendada";

        return sessao.Fim.ToUniversalTime() >= agora ? "ADecorrer" : "Terminada";
    }

    private static string EstadoCss(string estado)
    {
        if (string.Equals(estado, "ADecorrer", StringComparison.OrdinalIgnoreCase))
            return "live";

        if (string.Equals(estado, "Terminada", StringComparison.OrdinalIgnoreCase))
            return "ended";

        return "scheduled";
    }

    private static string EstadoFestival(FestivalDTO festival)
    {
        var agora = DateTime.Now;

        if (agora < festival.StartDate)
            return "Em breve";

        if (agora <= festival.EndDate)
            return "A decorrer";

        return "Terminado";
    }

    private static string FormatarPeriodo(DateTime inicio, DateTime fim)
    {
        if (inicio.Year == fim.Year && inicio.Month == fim.Month)
            return $"{inicio:dd} - {fim:dd MMM yyyy}";

        return $"{inicio:dd/MM/yyyy} - {fim:dd/MM/yyyy}";
    }

    private static string Moeda(decimal valor)
    {
        return valor.ToString("C", new System.Globalization.CultureInfo("pt-PT"));
    }
}
