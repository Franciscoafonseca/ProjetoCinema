@page "/filmes/{Id:int}"
@inherits FilmePageBase
@inject FilmeService FilmeService
@inject SessaoService SessaoService
@inject AcessoService AcessoService
@inject CarrinhoService CarrinhoService
@inject AvaliacaoService AvaliacaoService
@inject ListaService ListaService
@inject NavigationManager Nav

<PageTitle>@(_filme?.Titulo ?? "Filme") - Online Cinema Festival</PageTitle>

<main class="cinema-page detalhes-page">
    <section class="cinema-shell">
        @if (_loading)
        {
            <div class="cinema-state">
                <div class="spinner"></div>
                <p>A carregar filme...</p>
            </div>
        }
        else if (_erro != null)
        {
            <div class="cinema-state error">
                <p>@_erro</p>
                <button class="cinema-btn secondary" @onclick="Voltar">Voltar ao catalogo</button>
            </div>
        }
        else if (_filme == null)
        {
            <div class="cinema-state">
                <p>Filme nao encontrado.</p>
                <button class="cinema-btn secondary" @onclick="Voltar">Voltar ao catalogo</button>
            </div>
        }
        else
        {
            <button class="back-link" @onclick="Voltar">Voltar ao catalogo</button>

            <section class="detalhes-hero cinema-panel">
                <div class="detalhes-poster">
                    <img src="@ImagemFilme(_filme)" alt="@_filme.Titulo" />
                </div>

                <div class="detalhes-info">
                    <span class="cinema-kicker">@GeneroFilme(_filme)</span>
                    <h1>@_filme.Titulo</h1>

                    <div class="chip-row">
                        <span>@AnoFilme(_filme)</span>
                        <span>@Duracao(_filme)</span>
                        @if (!string.IsNullOrWhiteSpace(_filme.Classificacao))
                        {
                            <span>TMDB @_filme.Classificacao</span>
                        }
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_filme.Sinopse))
                    {
                        <p class="sinopse">@_filme.Sinopse</p>
                    }

                    <dl class="facts-grid">
                        <div>
                            <dt>Realizador</dt>
                            <dd>@ValorOuIndisponivel(_filme.Realizador)</dd>
                        </div>
                        <div>
                            <dt>Atores</dt>
                            <dd>@(_filme.Atores.Count == 0 ? "N/D" : string.Join(", ", _filme.Atores.Take(5)))</dd>
                        </div>
                        <div>
                            <dt>Festivais</dt>
                            <dd>@(_filme.Festivais.Count == 0 ? "N/D" : string.Join(", ", _filme.Festivais.Select(f => f.Name)))</dd>
                        </div>
                        <div>
                            <dt>Premios</dt>
                            <dd>@ValorOuIndisponivel(_filme.Premios)</dd>
                        </div>
                    </dl>

                    <div class="hero-actions">
                        @if (_filme.PodeVer)
                        {
                            <button class="cinema-btn primary" @onclick="AbrirPlayerFilme">Ver agora</button>
                        }
                        else
                        {
                            <a class="cinema-btn secondary" href="#acessos">Comprar acesso</a>
                        }
                        <a class="cinema-btn ghost" href="/carrinho">Carrinho</a>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_mensagemCarrinho))
                    {
                        <MudAlert Severity="@_mensagemCarrinhoSeveridade" Variant="Variant.Filled">
                            @_mensagemCarrinho
                        </MudAlert>
                    }
                </div>
            </section>

            @if (!string.IsNullOrWhiteSpace(TrailerEmbedUrl))
            {
                <section class="cinema-panel trailer-section">
                    <div class="cinema-section-head compact">
                        <div>
                            <span class="cinema-kicker">Trailer</span>
                            <h2>Antevisao</h2>
                        </div>
                    </div>
                    <div class="trailer-wrapper">
                        <iframe src="@TrailerEmbedUrl"
                                title="Trailer de @_filme.Titulo"
                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                                allowfullscreen>
                        </iframe>
                    </div>
                </section>
            }

            <section id="acessos" class="access-section">
                <div class="cinema-section-head">
                    <div>
                        <span class="cinema-kicker">Acessos</span>
                        <h2>Escolhe como queres ver</h2>
                    </div>
                </div>

                <div class="access-choice-grid">
                    <article class="access-choice cinema-panel">
                        <span>Bilhete de sessao</span>
                        <h3>Comprar bilhete</h3>
                        <p>Seleciona uma sessao programada para este filme.</p>
                        @if (_sessoes.Count == 0)
                        {
                            <small>Sem sessoes disponiveis.</small>
                        }
                        else
                        {
                            <select @bind="_sessaoSelecionadaId">
                                <option value="">Selecionar sessao</option>
                                @foreach (var sessao in _sessoes)
                                {
                                    <option value="@sessao.Id">@TituloSessao(sessao) - @FormatarDataHora(sessao.Inicio)</option>
                                }
                            </select>
                            <button class="cinema-btn primary" disabled="@(!_sessaoSelecionadaId.HasValue || _aAtualizarCarrinho)" @onclick="AdicionarBilheteSelecionado">
                                Adicionar bilhete
                            </button>
                        }
                    </article>

                    <article class="access-choice cinema-panel">
                        <span>Passe diario</span>
                        <h3>Acesso de um dia</h3>
                        <p>Escolhe uma data dentro do festival associado.</p>
                        <select @bind="_festivalSelecionadoId">
                            <option value="">Selecionar festival</option>
                            @foreach (var festival in _filme.Festivais)
                            {
                                <option value="@festival.Id">@festival.Name</option>
                            }
                        </select>
                        <InputDate class="date-input" @bind-Value="_dataPasseDiario" />
                        <button class="cinema-btn secondary" disabled="@(!_festivalSelecionadoId.HasValue || _aAtualizarCarrinho)" @onclick="AdicionarPasseDiario">
                            Adicionar passe diario
                        </button>
                    </article>

                    <article class="access-choice cinema-panel">
                        <span>Passe completo</span>
                        <h3>Festival inteiro</h3>
                        <p>Compra acesso completo ao festival selecionado.</p>
                        <select @bind="_festivalSelecionadoId">
                            <option value="">Selecionar festival</option>
                            @foreach (var festival in _filme.Festivais)
                            {
                                <option value="@festival.Id">@festival.Name</option>
                            }
                        </select>
                        <button class="cinema-btn secondary" disabled="@(!_festivalSelecionadoId.HasValue || _aAtualizarCarrinho)" @onclick="AdicionarPasseCompleto">
                            Adicionar passe completo
                        </button>
                    </article>

                    <article class="access-choice cinema-panel">
                        <span>Aluguer 48h</span>
                        <h3>Alugar filme</h3>
                        <p>Depois da compra, o aluguer fica valido durante 48 horas.</p>
                        <button class="cinema-btn primary" disabled="@_aAtualizarCarrinho" @onclick="AdicionarAluguer">
                            Alugar por 48h
                        </button>
                    </article>
                </div>
            </section>

            <section class="cinema-panel sessoes-section">
                <div class="cinema-section-head compact">
                    <div>
                        <span class="cinema-kicker">Programa</span>
                        <h2>Sessoes deste filme</h2>
                    </div>
                    <a class="cinema-link" href="/sessoes">Ver programacao</a>
                </div>

                @if (_sessoes.Count == 0)
                {
                    <div class="cinema-state slim">Ainda nao ha sessoes programadas.</div>
                }
                else
                {
                    <div class="quick-list">
                        @foreach (var sessao in _sessoes)
                        {
                            <article class="quick-item">
                                <div class="quick-date">
                                    <span>@sessao.Inicio.ToLocalTime().ToString("dd/MM")</span>
                                    <strong>@sessao.Inicio.ToLocalTime().ToString("HH:mm")</strong>
                                </div>
                                <div class="quick-main">
                                    <strong>@TituloSessao(sessao)</strong>
                                    <small>@sessao.Festival</small>
                                </div>
                                <button class="cinema-btn ghost" @onclick="() => AbrirPlayerSessao(sessao.Id)">Ver agora</button>
                            </article>
                        }
                    </div>
                }
            </section>

            <section class="reviews-grid">
                <article class="cinema-panel">
                    <div class="cinema-section-head compact">
                        <div>
                            <span class="cinema-kicker">Comunidade</span>
                            <h2>Reviews da aplicacao</h2>
                        </div>
                        <div class="review-score">
                            <strong>@MediaAplicacao()</strong>
                            <span>@_filme.ReviewsAplicacao.Count reviews</span>
                        </div>
                    </div>

                    @if (_filme.ReviewsAplicacao.Count == 0)
                    {
                        <div class="cinema-state slim">Ainda nao ha reviews da comunidade.</div>
                    }
                    else
                    {
                        <div class="review-list featured">
                            @foreach (var review in _filme.ReviewsAplicacao.OrderByDescending(r => r.Data).Take(6))
                            {
                                <article>
                                    <strong>@review.NomeUsuario</strong>
                                    <span>Comunidade - @review.Pontuacao/10</span>
                                    <p>@review.Texto</p>
                                </article>
                            }
                        </div>
                    }

                    <AuthorizeView>
                        <Authorized Context="reviewAuth">
                            @if (_filme.PodeAvaliar)
                            {
                                <EditForm Model="_novaReview" OnValidSubmit="EnviarReview">
                                    <div class="review-form">
                                        <InputNumber class="text-input" @bind-Value="_novaReview.Pontuacao" />
                                        <InputTextArea class="text-area" @bind-Value="_novaReview.Texto" placeholder="Escreve a tua review" />
                                        <button class="cinema-btn primary" disabled="@_aEnviarReview" type="submit">
                                            @(_aEnviarReview ? "A publicar..." : "Publicar review")
                                        </button>
                                    </div>
                                </EditForm>
                            }
                            else
                            {
                                <div class="review-lock">So podes avaliar este filme depois de o veres atraves da plataforma.</div>
                            }
                        </Authorized>
                        <NotAuthorized>
                            <div class="review-lock">Inicia sessao para avaliar depois de veres o filme.</div>
                        </NotAuthorized>
                    </AuthorizeView>

                    @if (!string.IsNullOrWhiteSpace(_mensagemReview))
                    {
                        <MudAlert Severity="@_mensagemReviewSeveridade" Variant="Variant.Filled">@_mensagemReview</MudAlert>
                    }
                </article>

                <article class="cinema-panel">
                    <div class="cinema-section-head compact">
                        <div>
                            <span class="cinema-kicker">TMDB</span>
                            <h2>Reviews externas</h2>
                        </div>
                    </div>

                    @if (_filme.ReviewsTmdb.Count == 0)
                    {
                        <div class="cinema-state slim">Sem reviews TMDB disponiveis.</div>
                    }
                    else
                    {
                        <div class="review-list">
                            @foreach (var review in _filme.ReviewsTmdb.Take(4))
                            {
                                <article>
                                    <strong>@review.Autor</strong>
                                    <span>TMDB@(review.Nota.HasValue ? $" - {review.Nota:0.0}/10" : "")</span>
                                    <p>@ResumoReview(review.Texto)</p>
                                </article>
                            }
                        </div>
                    }
                </article>
            </section>

            <section class="cinema-panel listas-section">
                <div class="cinema-section-head compact">
                    <div>
                        <span class="cinema-kicker">Listas</span>
                        <h2>Guardar filme</h2>
                    </div>
                </div>

                <AuthorizeView>
                    <Authorized Context="listaAuth">
                        <div class="list-actions">
                            @foreach (var lista in ListasOrdenadas())
                            {
                                <button class="cinema-btn @(ListaTemFilme(lista) ? "primary" : "secondary")"
                                        disabled="@_aAtualizarLista"
                                        @onclick="() => AlternarLista(lista)">
                                    @RotuloLista(lista)
                                </button>
                            }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(_mensagemListas))
                        {
                            <MudAlert Severity="@_mensagemListasSeveridade" Variant="Variant.Filled">@_mensagemListas</MudAlert>
                        }
                    </Authorized>
                    <NotAuthorized>
                        <div class="cinema-state slim">Inicia sessao para adicionar este filme as tuas listas.</div>
                    </NotAuthorized>
                </AuthorizeView>
            </section>
        }
    </section>
</main>

@code {
    [Parameter] public int Id { get; set; }

    private FilmeDTO? _filme;
    private List<SessaoDTO> _sessoes = new();
    private List<AcessoDTO> _acessos = new();
    private List<ListaPessoalDTO> _listas = new();
    private int? _sessaoSelecionadaId;
    private int? _festivalSelecionadoId;
    private DateTime _dataPasseDiario = DateTime.Today;
    private bool _aAtualizarCarrinho;
    private bool _aEnviarReview;
    private bool _aAtualizarLista;
    private string? _mensagemCarrinho;
    private Severity _mensagemCarrinhoSeveridade = Severity.Info;
    private string? _mensagemReview;
    private Severity _mensagemReviewSeveridade = Severity.Info;
    private string? _mensagemListas;
    private Severity _mensagemListasSeveridade = Severity.Info;
    private CriarAvaliacaoDTO _novaReview = new() { Pontuacao = 8 };

    private string? TrailerEmbedUrl => ConverterParaEmbed(_filme?.TrailerUrl);

    protected override async Task CarregarDadosAsync()
    {
        _filme = await FilmeService.ObterFilmePorIdAsync(Id);

        if (_filme == null)
            return;

        _sessoes = _filme.Sessoes.Count > 0
            ? _filme.Sessoes.OrderBy(s => s.Inicio).ToList()
            : (await SessaoService.ObterSessoesPorFilmeAsync(Id)).OrderBy(s => s.Inicio).ToList();

        _acessos = _filme.AcessosDisponiveis.Count > 0
            ? _filme.AcessosDisponiveis
            : await AcessoService.ObterAcessosAsync();

        _listas = await ListaService.ObterMinhasListasAsync();
    }

    private async Task AdicionarBilheteSelecionado()
    {
        if (_sessaoSelecionadaId.HasValue)
            await AdicionarAoCarrinho(() => CarrinhoService.AdicionarBilheteSessaoAsync(_sessaoSelecionadaId.Value), "Bilhete adicionado ao carrinho.");
    }

    private async Task AdicionarPasseDiario()
    {
        if (_festivalSelecionadoId.HasValue)
            await AdicionarAoCarrinho(() => CarrinhoService.AdicionarPasseDiarioAsync(_festivalSelecionadoId.Value, _dataPasseDiario), "Passe diario adicionado ao carrinho.");
    }

    private async Task AdicionarPasseCompleto()
    {
        if (_festivalSelecionadoId.HasValue)
            await AdicionarAoCarrinho(() => CarrinhoService.AdicionarPasseCompletoAsync(_festivalSelecionadoId.Value), "Passe completo adicionado ao carrinho.");
    }

    private async Task AdicionarAluguer()
    {
        await AdicionarAoCarrinho(() => CarrinhoService.AdicionarAluguerDigitalAsync(Id), "Aluguer digital adicionado ao carrinho. Valido por 48h apos a compra.");
    }

    private async Task AdicionarAoCarrinho(Func<Task<CarrinhoDTO>> acao, string sucesso)
    {
        _mensagemCarrinho = null;
        _aAtualizarCarrinho = true;

        try
        {
            await acao();
            _mensagemCarrinhoSeveridade = Severity.Success;
            _mensagemCarrinho = sucesso;
        }
        catch (Exception ex)
        {
            _mensagemCarrinhoSeveridade = Severity.Error;
            _mensagemCarrinho = ex.Message;
        }
        finally
        {
            _aAtualizarCarrinho = false;
        }
    }

    private async Task EnviarReview()
    {
        if (_novaReview.Pontuacao < 1 || _novaReview.Pontuacao > 10)
        {
            _mensagemReviewSeveridade = Severity.Error;
            _mensagemReview = "A pontuacao deve estar entre 1 e 10.";
            return;
        }

        _aEnviarReview = true;
        _mensagemReview = null;

        try
        {
            var review = await AvaliacaoService.CriarAsync(Id, _novaReview);
            _filme?.ReviewsAplicacao.Insert(0, review);
            _novaReview = new CriarAvaliacaoDTO { Pontuacao = 8 };
            _mensagemReviewSeveridade = Severity.Success;
            _mensagemReview = "Review publicada.";
        }
        catch (Exception ex)
        {
            _mensagemReviewSeveridade = Severity.Error;
            _mensagemReview = ex.Message;
        }
        finally
        {
            _aEnviarReview = false;
        }
    }

    private async Task AlternarLista(ListaPessoalDTO lista)
    {
        _aAtualizarLista = true;
        _mensagemListas = null;

        try
        {
            if (ListaTemFilme(lista))
            {
                await ListaService.RemoverFilmeAsync(lista.Id, Id);
                lista.Items.RemoveAll(i => i.FilmeId == Id);
                _mensagemListas = "Filme removido da lista.";
            }
            else
            {
                await ListaService.AdicionarFilmeAsync(lista.Id, Id);
                lista.Items.Add(new ListaPessoalItemDTO { FilmeId = Id, Titulo = _filme?.Titulo ?? "" });
                _mensagemListas = "Filme adicionado a lista.";
            }

            _mensagemListasSeveridade = Severity.Success;
        }
        catch (Exception ex)
        {
            _mensagemListasSeveridade = Severity.Error;
            _mensagemListas = ex.Message;
        }
        finally
        {
            _aAtualizarLista = false;
        }
    }

    private IEnumerable<ListaPessoalDTO> ListasOrdenadas()
    {
        return _listas.OrderBy(l => l.Tipo == TipoListaPessoal.Custom ? 1 : 0).ThenBy(l => l.Name);
    }

    private bool ListaTemFilme(ListaPessoalDTO lista)
    {
        return lista.Items.Any(i => i.FilmeId == Id);
    }

    private static string RotuloLista(ListaPessoalDTO lista)
    {
        return lista.Tipo switch
        {
            TipoListaPessoal.Watchlist => "Quero ver",
            TipoListaPessoal.Watched => "Vistos",
            TipoListaPessoal.Favorites => "Favoritos",
            _ => string.IsNullOrWhiteSpace(lista.Name) ? "Lista personalizada" : lista.Name,
        };
    }

    private void AbrirPlayerFilme() => Nav.NavigateTo($"/visualizar/filme/{Id}");

    private void AbrirPlayerSessao(int sessaoId) => Nav.NavigateTo($"/visualizar/sessao/{sessaoId}");

    private void Voltar() => Nav.NavigateTo("/catalogo");

    private static string ImagemFilme(FilmeDTO filme)
    {
        return string.IsNullOrWhiteSpace(filme.CapaUrl)
            ? "https://placehold.co/500x750/111827/ffffff?text=OCF"
            : filme.CapaUrl;
    }

    private static string AnoFilme(FilmeDTO filme)
    {
        return filme.DataLancamento == default ? "N/D" : filme.DataLancamento.Year.ToString();
    }

    private static string Duracao(FilmeDTO filme)
    {
        return filme.DuracaoMinutos.HasValue ? $"{filme.DuracaoMinutos} min" : "Duracao N/D";
    }

    private static string GeneroFilme(FilmeDTO filme)
    {
        if (filme.Generos.Count > 0)
            return string.Join(", ", filme.Generos);

        return string.IsNullOrWhiteSpace(filme.Genero) ? "Cinema" : filme.Genero;
    }

    private static string ValorOuIndisponivel(string? valor)
    {
        return string.IsNullOrWhiteSpace(valor) ? "N/D" : valor;
    }

    private static string TituloSessao(SessaoDTO sessao)
    {
        return string.IsNullOrWhiteSpace(sessao.Filme) ? $"Sessao #{sessao.Id}" : sessao.Filme;
    }

    private static string FormatarDataHora(DateTime valor)
    {
        return valor.ToLocalTime().ToString("dd/MM/yyyy HH:mm");
    }

    private string MediaAplicacao()
    {
        if (_filme?.ReviewsAplicacao.Count > 0)
            return _filme.ReviewsAplicacao.Average(r => r.Pontuacao).ToString("0.0");

        return "N/D";
    }

    private static string ResumoReview(string texto)
    {
        if (string.IsNullOrWhiteSpace(texto))
            return "Sem texto.";

        return texto.Length <= 260 ? texto : texto[..260] + "...";
    }

    private static string? ConverterParaEmbed(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
            return null;

        if (url.Contains("/embed/", StringComparison.OrdinalIgnoreCase))
            return url;

        if (Uri.TryCreate(url, UriKind.Absolute, out var uri))
        {
            if (uri.Host.Contains("youtu.be", StringComparison.OrdinalIgnoreCase))
                return $"https://www.youtube.com/embed/{uri.AbsolutePath.Trim('/')}";

            var videoId = uri.Query
                .TrimStart('?')
                .Split('&', StringSplitOptions.RemoveEmptyEntries)
                .Select(parte => parte.Split('=', 2))
                .FirstOrDefault(partes =>
                    partes.Length == 2 && string.Equals(partes[0], "v", StringComparison.OrdinalIgnoreCase)
                )?[1];

            if (!string.IsNullOrWhiteSpace(videoId))
                return $"https://www.youtube.com/embed/{Uri.UnescapeDataString(videoId)}";
        }

        return url;
    }
}
