@page "/filmes/{Id:int}"
@inherits FilmePageBase
@inject FilmeService FilmeService
@inject SessaoService SessaoService
@inject AcessoService AcessoService
@inject CarrinhoService CarrinhoService
@inject NavigationManager Nav

<PageTitle>@(_filme?.Titulo ?? "Filme") - Online Cinema Festival</PageTitle>

@if (_loading)
{
    <div class="loading-state">
        <div class="spinner"></div>
        <p>A carregar filme...</p>
    </div>
}
else if (_erro != null)
{
    <div class="nao-encontrado">
        <p class="erro-msg">@_erro</p>
        <button class="btn-voltar" @onclick="Voltar">Voltar ao catalogo</button>
    </div>
}
else if (_filme == null)
{
    <div class="nao-encontrado">
        <h2>Filme nao encontrado</h2>
        <button class="btn-voltar" @onclick="Voltar">Voltar ao catalogo</button>
    </div>
}
else
{
    <div class="detalhes-container">
        <button class="btn-voltar" @onclick="Voltar">Voltar ao catalogo</button>

        <section class="detalhes-hero">
            <div class="detalhes-poster">
                <img src="@ImagemFilme(_filme)" alt="@_filme.Titulo" />
            </div>

            <div class="detalhes-info">
                @if (!string.IsNullOrWhiteSpace(_filme.Genero))
                {
                    <span class="detalhes-genero">@_filme.Genero</span>
                }

                <h1 class="detalhes-titulo">@_filme.Titulo</h1>

                <div class="detalhes-meta">
                    <div class="meta-item">
                        <span class="meta-label">Ano</span>
                        <span>@AnoFilme(_filme)</span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_filme.Classificacao))
                    {
                        <div class="meta-item">
                            <span class="star">*</span>
                            <span>@_filme.Classificacao</span>
                        </div>
                    }
                    <div class="meta-item">
                        <span class="meta-label">Popularidade</span>
                        <span>@_filme.Popularidade</span>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(_filme.Sinopse))
                {
                    <p class="detalhes-sinopse">@_filme.Sinopse</p>
                }

                <div class="player-acoes">
                    <AuthorizeView>
                        <Authorized>
                            <button class="btn-ver" @onclick="AbrirPlayerFilme">
                                Ver no player
                            </button>
                        </Authorized>
                        <NotAuthorized>
                            <a class="btn-ver link-login" href="@LoginUrl()">Entrar para ver</a>
                        </NotAuthorized>
                    </AuthorizeView>

                    <a class="link-carrinho" href="/carrinho">Carrinho</a>
                </div>

                @if (!string.IsNullOrWhiteSpace(_mensagemCarrinho))
                {
                    <p class="carrinho-feedback">@_mensagemCarrinho</p>
                }
            </div>
        </section>

        @if (!string.IsNullOrWhiteSpace(TrailerEmbedUrl))
        {
            <section class="trailer-seccao">
                <h2 class="seccao-titulo">Trailer</h2>
                <div class="trailer-wrapper">
                    <iframe src="@TrailerEmbedUrl"
                            title="Trailer de @_filme.Titulo"
                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                            allowfullscreen>
                    </iframe>
                </div>
            </section>
        }

        <section class="sessoes-seccao">
            <div class="section-heading-inline">
                <h2 class="seccao-titulo">Sessoes</h2>
                <a href="/sessoes">Ver programacao</a>
            </div>

            @if (_sessoes.Count == 0)
            {
                <p class="empty-state">Ainda nao ha sessoes programadas para este filme.</p>
            }
            else
            {
                <div class="sessoes-lista">
                    @foreach (var sessao in _sessoes)
                    {
                        <article class="sessao-cartao">
                            <div class="sessao-cartao-cabecalho">
                                <div class="sessao-cartao-data">
                                    <span class="sessao-cartao-dia">@sessao.Inicio.ToLocalTime().ToString("dd")</span>
                                    <span class="sessao-cartao-mes">@sessao.Inicio.ToLocalTime().ToString("MMM").ToUpperInvariant()</span>
                                </div>

                                <div class="sessao-cartao-info">
                                    <div class="sessao-cartao-festival">@sessao.Festival</div>
                                    <div class="sessao-cartao-hora">
                                        @sessao.TipoNome - @FormatarDataHora(sessao.Inicio) - @sessao.Fim.ToLocalTime().ToString("HH:mm")
                                    </div>
                                </div>

                                <span class="status @EstadoCss(EstadoTexto(sessao))">@EstadoTexto(sessao)</span>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(sessao.Observacoes))
                            {
                                <p class="sessao-observacoes">@sessao.Observacoes</p>
                            }

                            <div class="sessao-acoes">
                                <button class="btn-comprar"
                                        disabled="@(_aAtualizarCarrinho || SessaoTerminada(sessao))"
                                        @onclick="() => AdicionarBilhete(sessao.Id)">
                                    Bilhete
                                </button>
                                <button class="btn-ver-sessao" @onclick="() => AbrirPlayerSessao(sessao.Id)">
                                    Player
                                </button>
                            </div>
                        </article>
                    }
                </div>
            }
        </section>

        <section class="acessos-filme">
            <h2 class="seccao-titulo">Acessos digitais</h2>

            @if (AcessosDoFilme.Count == 0)
            {
                <p class="sem-acessos">Ainda nao ha aluguer digital configurado para este filme.</p>
            }
            else
            {
                <div class="acessos-lista">
                    @foreach (var acesso in AcessosDoFilme)
                    {
                        <article class="acesso-item">
                            <div class="acesso-info">
                                <span class="acesso-nome">@acesso.Nome</span>
                                <span class="acesso-tipo">@DescricaoAcesso(acesso)</span>
                            </div>
                            <div class="acesso-acao">
                                <span class="acesso-preco">@Moeda(acesso.Preco)</span>
                                <button class="btn-comprar"
                                        disabled="@_aAtualizarCarrinho"
                                        @onclick="() => AdicionarAluguer()">
                                    Alugar
                                </button>
                            </div>
                        </article>
                    }
                </div>
            }
        </section>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private FilmeDto? _filme;
    private List<SessaoDto> _sessoes = new();
    private List<AcessoDto> _acessos = new();
    private bool _aAtualizarCarrinho;
    private string? _mensagemCarrinho;

    private string? TrailerEmbedUrl => ConverterParaEmbed(_filme?.TrailerUrl);

    private List<AcessoDto> AcessosDoFilme =>
        _acessos
            .Where(a => a.IsAtivo && a.Tipo == TiposAcesso.AluguerDigital && a.FilmeId == Id)
            .OrderBy(a => a.Preco)
            .ToList();

    protected override async Task CarregarDadosAsync()
    {
        _filme = await FilmeService.GetFilmeByIdAsync(Id);

        if (_filme == null)
            return;

        _sessoes = (await SessaoService.GetSessoesPorFilmeAsync(Id))
            .OrderBy(s => s.Inicio)
            .ToList();

        _acessos = await AcessoService.GetAcessosAsync();
    }

    private async Task AdicionarBilhete(int sessaoId)
    {
        await ExecutarCarrinho(async () =>
        {
            await CarrinhoService.AdicionarBilheteSessaoAsync(sessaoId);
            _mensagemCarrinho = "Bilhete adicionado ao carrinho.";
        });
    }

    private async Task AdicionarAluguer()
    {
        await ExecutarCarrinho(async () =>
        {
            await CarrinhoService.AdicionarAluguerDigitalAsync(Id);
            _mensagemCarrinho = "Aluguer digital adicionado ao carrinho.";
        });
    }

    private async Task ExecutarCarrinho(Func<Task> acao)
    {
        _mensagemCarrinho = null;
        _aAtualizarCarrinho = true;

        try
        {
            await acao();
        }
        catch (Exception ex)
        {
            _mensagemCarrinho = ex.Message;
        }
        finally
        {
            _aAtualizarCarrinho = false;
        }
    }

    private void AbrirPlayerFilme() => Nav.NavigateTo($"/player/filme/{Id}");

    private void AbrirPlayerSessao(int sessaoId) => Nav.NavigateTo($"/player/sessao/{sessaoId}");

    private void Voltar() => Nav.NavigateTo("/catalogo");

    private string LoginUrl() => $"/login?returnUrl={Uri.EscapeDataString($"/filmes/{Id}")}";

    private static string ImagemFilme(FilmeDto filme)
    {
        return string.IsNullOrWhiteSpace(filme.CapaUrl)
            ? "https://placehold.co/500x750/171717/ffffff?text=Filme"
            : filme.CapaUrl;
    }

    private static string AnoFilme(FilmeDto filme)
    {
        return filme.DataLancamento == default ? "N/D" : filme.DataLancamento.Year.ToString();
    }

    private static bool SessaoTerminada(SessaoDto sessao)
    {
        return string.Equals(EstadoTexto(sessao), "Terminada", StringComparison.OrdinalIgnoreCase)
            || sessao.Fim.ToUniversalTime() <= DateTime.UtcNow;
    }

    private static string EstadoTexto(SessaoDto sessao)
    {
        if (!string.IsNullOrWhiteSpace(sessao.Estado))
            return sessao.Estado;

        var agora = DateTime.UtcNow;
        if (sessao.Inicio.ToUniversalTime() > agora)
            return "Agendada";

        return sessao.Fim.ToUniversalTime() >= agora ? "ADecorrer" : "Terminada";
    }

    private static string EstadoCss(string estado)
    {
        if (string.Equals(estado, "ADecorrer", StringComparison.OrdinalIgnoreCase))
            return "live";

        if (string.Equals(estado, "Terminada", StringComparison.OrdinalIgnoreCase))
            return "ended";

        return "scheduled";
    }

    private static string DescricaoAcesso(AcessoDto acesso)
    {
        if (acesso.DuracaoHoras.HasValue)
            return $"{acesso.TipoNome} - {acesso.DuracaoHoras}h";

        return acesso.TipoNome;
    }

    private static string FormatarDataHora(DateTime valor)
    {
        return valor.ToLocalTime().ToString("dd/MM/yyyy HH:mm");
    }

    private static string Moeda(decimal valor)
    {
        return valor.ToString("C", new System.Globalization.CultureInfo("pt-PT"));
    }

    private static string? ConverterParaEmbed(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
            return null;

        if (url.Contains("/embed/", StringComparison.OrdinalIgnoreCase))
            return url;

        if (Uri.TryCreate(url, UriKind.Absolute, out var uri))
        {
            if (uri.Host.Contains("youtu.be", StringComparison.OrdinalIgnoreCase))
                return $"https://www.youtube.com/embed/{uri.AbsolutePath.Trim('/')}";

            var videoId = uri.Query
                .TrimStart('?')
                .Split('&', StringSplitOptions.RemoveEmptyEntries)
                .Select(parte => parte.Split('=', 2))
                .FirstOrDefault(partes =>
                    partes.Length == 2 && string.Equals(partes[0], "v", StringComparison.OrdinalIgnoreCase)
                )?[1];

            if (!string.IsNullOrWhiteSpace(videoId))
                return $"https://www.youtube.com/embed/{Uri.UnescapeDataString(videoId)}";
        }

        return url;
    }
}
