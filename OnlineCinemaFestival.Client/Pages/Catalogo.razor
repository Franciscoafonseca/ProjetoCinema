@page "/catalogo"
@inherits FilmePageBase
@inject FilmeService FilmeService

<PageTitle>Catálogo — Online Cinema Festival</PageTitle>

<div class="catalogo-container">
    <h1 class="catalogo-titulo">Catálogo</h1>

    <div class="catalogo-filtros">
        <input class="pesquisa-input"
               type="text"
               placeholder="Pesquisar por título ou sinopse..."
               value="@_pesquisa"
               @oninput="OnPesquisaAlterada" />

        <div class="filtro-genero">
            <MudMenu Label="@RotuloFiltro()"
                     Variant="Variant.Outlined"
                     Color="Color.Primary"
                     StartIcon="@Icons.Material.Filled.FilterList"
                     EndIcon="@Icons.Material.Filled.ArrowDropDown"
                     IconColor="Color.Primary"
                     AnchorOrigin="Origin.BottomLeft"
                     TransformOrigin="Origin.TopLeft"
                     MaxHeight="360">
                @if (_generosSelecionados.Count > 0)
                {
                    <MudMenuItem OnClick="LimparGeneros" AutoClose="false">
                        Limpar seleção
                    </MudMenuItem>
                    <MudDivider />
                }
                @foreach (var genero in _generos)
                {
                    <MudMenuItem OnClick="() => AlternarGenero(genero)" AutoClose="false">
                        @(_generosSelecionados.Contains(genero) ? $"✓ {genero}" : genero)
                    </MudMenuItem>
                }
            </MudMenu>

            @if (_generosSelecionados.Count > 0)
            {
                <div class="chips-selecionados">
                    @foreach (var genero in _generosSelecionados.OrderBy(g => g))
                    {
                        <MudChip T="string"
                                 Color="Color.Primary"
                                 Variant="Variant.Filled"
                                 OnClose="() => AlternarGenero(genero)"
                                 CloseIcon="@Icons.Material.Filled.Close">
                            @genero
                        </MudChip>
                    }
                </div>
            }
        </div>
    </div>

    @if (_loading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>A carregar filmes...</p>
        </div>
    }
    else if (_erro != null)
    {
        <p class="erro-state">@_erro</p>
    }
    else if (_filmes.Count == 0)
    {
        <p class="empty-state">Nenhum filme encontrado.</p>
    }
    else
    {
        <div class="catalogo-grid">
            @foreach (var filme in _filmes)
            {
                <FilmeCard Filme="filme" />
            }
        </div>
    }
</div>

@code {
    private List<FilmeDto> _filmes = new();
    private List<string> _generos = new();
    private readonly HashSet<string> _generosSelecionados = new(StringComparer.OrdinalIgnoreCase);
    private string? _pesquisa;

    protected override async Task CarregarDadosAsync()
    {
        _generos = await FilmeService.GetGenerosAsync();
        _filmes = await FilmeService.GetFilmesAsync();
    }

    private async Task AlternarGenero(string genero)
    {
        if (!_generosSelecionados.Add(genero))
            _generosSelecionados.Remove(genero);

        await AplicarFiltros();
    }

    private async Task LimparGeneros()
    {
        _generosSelecionados.Clear();
        await AplicarFiltros();
    }

    private async Task OnPesquisaAlterada(ChangeEventArgs e)
    {
        _pesquisa = e.Value?.ToString();
        await AplicarFiltros();
    }

    private async Task AplicarFiltros()
    {
        var filmes = await FilmeService.GetFilmesAsync(null, _pesquisa);

        if (_generosSelecionados.Count > 0)
        {
            filmes = filmes
                .Where(f =>
                {
                    var generos = GenerosDoFilme(f.Genero).ToHashSet(StringComparer.OrdinalIgnoreCase);
                    return _generosSelecionados.All(g => generos.Contains(g));
                })
                .ToList();
        }

        _filmes = filmes;
    }

    private static IEnumerable<string> GenerosDoFilme(string? generos)
    {
        if (string.IsNullOrWhiteSpace(generos))
            return Array.Empty<string>();

        return generos
            .Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(g => g.Trim())
            .Where(g => g.Length > 0);
    }

    private string RotuloFiltro()
    {
        return _generosSelecionados.Count switch
        {
            0 => "Filtrar por género",
            1 => _generosSelecionados.First(),
            _ => $"{_generosSelecionados.Count} géneros",
        };
    }
}