@page "/historico"

<PageTitle>Historico — Online Cinema Festival</PageTitle>

<div class="history-shell">
    <section class="history-panel">
        <header class="panel-header">
            <div>
                <h2>Movies Purchased</h2>
                <span class="panel-sub">Ultimas aquisicoes</span>
            </div>
            <div class="panel-nav">
                <button class="nav-btn">&#8592;</button>
                <button class="nav-btn">&#8594;</button>
            </div>
        </header>
        <div class="panel-grid">
            @foreach (var item in MoviesPurchased)
            {
                <article class="poster-card">
                    <img src="@item.PosterUrl" alt="@item.Title" />
                    <div class="poster-meta">
                        <span>@item.Title</span>
                        <span class="tag">@item.Format</span>
                    </div>
                </article>
            }
        </div>
    </section>

    <section class="history-panel">
        <header class="panel-header">
            <div>
                <h2>Tickets</h2>
                <span class="panel-sub">Passes e bilhetes ativos</span>
            </div>
            <div class="panel-nav">
                <button class="nav-btn">&#8592;</button>
                <button class="nav-btn">&#8594;</button>
            </div>
        </header>
        <div class="panel-grid">
            @foreach (var item in Tickets)
            {
                <article class="poster-card">
                    <img src="@item.PosterUrl" alt="@item.Title" />
                    <div class="poster-meta">
                        <span>@item.Title</span>
                        <span class="tag">@item.Format</span>
                    </div>
                </article>
            }
        </div>
    </section>
</div>

