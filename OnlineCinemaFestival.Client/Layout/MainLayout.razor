@inherits LayoutComponentBase
@inject AuthService AuthService
@inject NavigationManager Nav

<MudThemeProvider Theme="_tema" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="layout">
    <header class="navbar-topo">
        <a class="logo" href="">
            <span class="logo-mark">OCF</span>
            <span>Online Cinema Festival</span>
        </a>

        <nav class="nav-centro" aria-label="Navegacao principal">
            <NavLink class="nav-btn" href="" Match="NavLinkMatch.All">Inicio</NavLink>
            <NavLink class="nav-btn" href="catalogo">Catalogo</NavLink>
            <NavLink class="nav-btn" href="festivais">Festivais</NavLink>
            <NavLink class="nav-btn" href="sessoes">Sessoes</NavLink>

            <AuthorizeView>
                <Authorized>
                    <NavLink class="nav-btn" href="meus-acessos">Acessos</NavLink>
                    <NavLink class="nav-btn" href="minhas-compras">Compras</NavLink>
                    <NavLink class="nav-btn" href="listas">Listas</NavLink>
                </Authorized>
            </AuthorizeView>
        </nav>

        <div class="nav-direita">
            <AuthorizeView>
                <Authorized Context="auth">
                    <NavLink class="nav-icon-btn" href="carrinho" title="Carrinho">Carrinho</NavLink>
                    <NavLink class="nav-user" href="perfil">@ObterNome(auth.User.Identity?.Name)</NavLink>
                    <button class="nav-btn nav-btn-sair" @onclick="Sair">Sair</button>
                </Authorized>
                <NotAuthorized>
                    <NavLink class="nav-btn" href="login">Entrar</NavLink>
                    <NavLink class="nav-btn nav-btn-destaque" href="registo">Registar</NavLink>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </header>

    <main class="conteudo">
        @Body
    </main>
</div>

@code {
    private readonly MudTheme _tema = new()
    {
        PaletteDark = new PaletteDark
        {
            Primary = "#e50914",
            Secondary = "#2dd4bf",
            Background = "#111111",
            Surface = "#1b1b1b",
            AppbarBackground = "#111111",
            TextPrimary = "#ffffff",
            TextSecondary = "#c8c8c8",
            ActionDefault = "#d8d8d8",
            DrawerBackground = "#171717",
        }
    };

    private async Task Sair()
    {
        await AuthService.TerminarSessaoAsync();
        Nav.NavigateTo("/");
    }

    private static string ObterNome(string? nome)
    {
        if (string.IsNullOrWhiteSpace(nome))
            return "Perfil";

        return nome.Contains('@') ? nome.Split('@')[0] : nome;
    }
}
