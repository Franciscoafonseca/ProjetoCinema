<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">OnlineCinemaFestival.Client</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="catalogo">
                <span class="bi bi-film" aria-hidden="true"></span> Catálogo
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="carrinho">
                <span class="bi bi-cart" aria-hidden="true"></span> Carrinho
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="minhas-compras">
                <span class="bi bi-receipt" aria-hidden="true"></span> Compras
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="perfil">
                <span class="bi bi-person-circle" aria-hidden="true"></span> Perfil
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="historico">
                <span class="bi bi-clock-history" aria-hidden="true"></span> Histórico
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="rewards">
                <span class="bi bi-gift" aria-hidden="true"></span> Rewards
            </NavLink>
        </div>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
